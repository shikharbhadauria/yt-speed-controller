{
  "manifest_version": 3,
  "name": "YT Speed+",
  "version": "1.0.0",
  "description": "Fine-grained YouTube speed control injected directly into the player bar.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
